    { "id": "awestruck",            "label": "Awestruck",              "family": "surprise",  "base_mode": "surprised", "eye_state": "wide",       "mouth_shape": "soft_small",       "accent": "sparkle",    "notes": "Quiet wonder. Reverent." },

    { "id": "pout",                 "label": "Pout",                   "family": "sadness",   "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "down_curve",       "accent": null,         "notes": "Mild disappointment." },
    { "id": "melancholy",           "label": "Melancholy",             "family": "sadness",   "base_mode": "idle",      "eye_state": "droop",      "mouth_shape": "down_curve",       "accent": null,         "notes": "Heavy lids, frown. Sustained sadness." },
