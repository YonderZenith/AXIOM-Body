    { "id": "scheming",             "label": "Scheming",               "family": "thinking",  "base_mode": "thinking",  "eye_state": "squint",     "mouth_shape": "asymmetric_smile", "glow": 0.6,            "accent": "thinking",   "notes": "Plotting at low glow. Devious." },
