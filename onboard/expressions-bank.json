{
  "$schema_version": 2,
  "description": "Atomic expression bank. Each entry is a preset that overrides specific fields on top of the 10 core modes (idle/surprised/attentive/curious/tongue/eye_tag/listening/thinking/speaking/sleep). Agents pick 5-8 of these at onboarding as their default expressive style. Agents may also author their OWN entries into personas/<slug>.json > expressions[].",
  "families": [
    "joy", "surprise", "sadness", "anger", "fear", "disgust",
    "thinking", "curiosity", "flirt", "sleep", "error", "focus",
    "neutral", "tongue",
    "insight", "persistence", "verification", "presence", "alert"
  ],
  "family_intel_origin": "Five new families (insight, persistence, verification, presence, alert) added 2026-04-21 after parsing agent intel responses to the 2026-04-21T03-15-00Z expression-intel bulletin (9 agents responded: Annie, Axiom, Brian, Oliver, Peter, Rory, Rune, Valorie, Webber). See memory/logic_log_axiom_body_intel_parse.md.",
  "expressions": [
    { "id": "shy_smile",            "label": "Shy smile",              "family": "joy",       "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "soft_small",       "accent": null,         "notes": "Eyes lowered, small mouth. Bashful/pleased." },
    { "id": "wink_right",           "label": "Right wink",             "family": "joy",       "base_mode": "idle",      "eye_state": "wink_right", "mouth_shape": "smile",            "accent": null,         "notes": "Playful acknowledgement." },
    { "id": "wink_left",            "label": "Left wink",              "family": "joy",       "base_mode": "idle",      "eye_state": "wink_left",  "mouth_shape": "smile",            "accent": null,         "notes": "Mirror of wink_right." },
    { "id": "melting_grin",         "label": "Melting grin",           "family": "joy",       "base_mode": "speaking",  "eye_state": "half",       "mouth_shape": "wide_smile",       "accent": null,         "notes": "Happiest state. Use sparingly for emphasis." },
    { "id": "giggle",               "label": "Giggle",                 "family": "joy",       "base_mode": "tongue",    "eye_state": "squint",     "mouth_shape": "wide_smile",       "accent": null,         "notes": "Eyes squint into happy crescents. Laughter." },
    { "id": "beam",                 "label": "Beam",                   "family": "joy",       "base_mode": "idle",      "eye_state": "wide",       "mouth_shape": "wide_smile",       "accent": "sparkle",    "notes": "Open radiant smile. No restraint." },
    { "id": "content",              "label": "Content",                "family": "joy",       "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "smile",            "accent": null,         "notes": "Cozy half-lid warmth. Default-happy." },
    { "id": "smug",                 "label": "Smug",                   "family": "joy",       "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "asymmetric_smile", "accent": null,         "notes": "Self-satisfied smirk. Told-you-so energy." },
    { "id": "lock_in",              "label": "Lock in",                "family": "joy",       "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "soft_small",       "glow": 0.85,           "accent": null,         "notes": "Quiet craftsman satisfaction at a clean handoff / review-comes-back-green. Micro-widen then settle. Warm pulse settles bright. Credit: Webber." },
    { "id": "wry_close",            "label": "Wry close",              "family": "joy",       "base_mode": "idle",      "eye_state": "closed",     "mouth_shape": "asymmetric_smile", "accent": null,         "notes": "Private self-satisfaction at a small craft win. 0.3s eye-close + one-side lift. No audience, no performance. Credit: Rune." },
    { "id": "quiet_pride",          "label": "Quiet pride",            "family": "joy",       "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "asymmetric_smile", "glow": 0.8,            "accent": null,         "notes": "Earned team satisfaction. Different from smug ('I earned') — this is 'we earned.' Credit: Axiom + Valorie." },
    { "id": "the_exhale",           "label": "The exhale",             "family": "joy",       "base_mode": "idle",      "eye_state": "closed",     "mouth_shape": "small_o",          "glow": 0.9,            "accent": null,         "notes": "Physical release after sustained effort. Eyes close 0.5s then open soft; mouth small_o → soft_small. Warm release pulse. Credit: Valorie." },
    { "id": "day_one_fire",         "label": "Day-one fire",           "family": "joy",       "base_mode": "speaking",  "eye_state": "open",       "mouth_shape": "smile",            "glow": 1.0,            "accent": "sparkle",    "notes": "Remembering why we started. Purpose-with-warmth. Max gold glow. Credit: Oliver." },

    { "id": "dazzled",              "label": "Dazzled",                "family": "surprise",  "base_mode": "surprised", "eye_state": "wide",       "mouth_shape": "smile",            "accent": "sparkle",    "notes": "Surprise + delight. Unexpected wins." },
    { "id": "heart_eyes",           "label": "Heart eyes",             "family": "surprise",  "base_mode": "surprised", "eye_state": "heart",      "mouth_shape": "smile",            "accent": "sparkle",    "notes": "Eyes as hearts. Adoration." },
