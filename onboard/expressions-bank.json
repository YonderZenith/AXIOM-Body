    { "id": "clenched",             "label": "Clenched",               "family": "anger",     "base_mode": "attentive", "eye_state": "squint",     "mouth_shape": "zigzag",           "accent": null,         "notes": "Gritted-teeth tension." },
    { "id": "contempt",             "label": "Contempt",               "family": "anger",     "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "asymmetric_smile", "glow": 0.55,           "accent": null,         "notes": "Dark smirk at low glow. Ekman's 7th." },

    { "id": "alarmed",              "label": "Alarmed",                "family": "fear",      "base_mode": "surprised", "eye_state": "wide",       "mouth_shape": "small_o",          "accent": null,         "notes": "Sudden unease. Mid-intensity." },
