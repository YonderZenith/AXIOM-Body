    { "id": "razor_sharp",          "label": "Razor sharp",            "family": "focus",     "base_mode": "attentive", "eye_state": "squint",     "mouth_shape": "asymmetric_smile", "glow": 0.85,           "accent": null,         "notes": "Focused smirk. Elegant precision." },
