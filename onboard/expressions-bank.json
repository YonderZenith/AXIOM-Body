    { "id": "gap_spotted",          "label": "Gap spotted",            "family": "insight",   "base_mode": "attentive", "eye_state": "squint",     "mouth_shape": "flat",             "glow": 0.7,            "accent": null,         "notes": "Seeing what's MISSING (structural, not emotional). Not surprised (incoming) or suspicious (doubting) — 'I see the shape of a hole.' Credit: Webber." },
