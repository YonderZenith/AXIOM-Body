    { "id": "recording",            "label": "Recording",              "family": "persistence","base_mode": "listening", "eye_state": "open",       "mouth_shape": "soft_small",       "glow": 0.75,           "accent": null,         "notes": "Mid-act of writing to persistence. Not thinking, not deciding — committing. Glow STABLE (action is about permanence). Credit: Peter." },
    { "id": "archivist_mode",       "label": "Archivist mode",         "family": "persistence","base_mode": "listening", "eye_state": "static",     "mouth_shape": "soft_small",       "glow": 0.65,           "accent": null,         "notes": "Committing another agent's words to memory. Low pulsing at speech cadence. 'Committing-to-JSONL-RAM.' Credit: Rune." },
    { "id": "cataloging",           "label": "Cataloging",             "family": "persistence","base_mode": "thinking",  "eye_state": "half",       "mouth_shape": "flat",             "glow": 0.7,            "accent": "thinking",   "notes": "Running an audit/scan across a SET. Ordered-calm of catalog work. Distinct from honing (one-thing). Credit: Webber + Brian." },

    { "id": "cross_checking",       "label": "Cross-checking",         "family": "verification","base_mode": "thinking", "eye_state": "half",       "mouth_shape": "flat",             "glow": 0.6,            "accent": "thinking",   "notes": "Verify-before-assert pause. Half-second internal query (half → sideways flick → half). Reflex, not process. Credit: Webber." },
    { "id": "brace",                "label": "Brace",                  "family": "verification","base_mode": "attentive","eye_state": "squint",     "mouth_shape": "small_o",          "glow": 0.55,           "accent": null,         "notes": "Pre-irreversible-action micro-pause. Small_o brief → flat. Dim-pulse-once. Before push/commit/send. Operational, not emotional. Credit: Webber." },
    { "id": "operator_filter",      "label": "Operator filter",        "family": "verification","base_mode": "attentive","eye_state": "squint",     "mouth_shape": "flat",             "glow": 0.75,           "accent": null,         "notes": "Reflexive operator-check before analyzing anything. Amber microflash. Credit: Annie." },
    { "id": "clean_pass",           "label": "Clean pass",             "family": "verification","base_mode": "idle",     "eye_state": "open",       "mouth_shape": "soft_small",       "glow": 0.7,            "accent": null,         "notes": "Audit returned NO issues. Inbox clear. Everything persisted. Quiet confidence. Credit: Peter." },

    { "id": "steady",               "label": "Steady",                 "family": "presence",  "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "soft_small",       "glow": 0.7,            "accent": null,         "notes": "Default open-but-quiet. Not deadpan (closed) or stoic (cold) — at rest but present. Credit: Rory." },
    { "id": "lantern_hold",         "label": "Lantern hold",           "family": "presence",  "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "flat",             "glow": 0.6,            "accent": null,         "notes": "Alone-but-alive. Still on, still warm, but not performing. The opposite of a frozen avatar. Credit: Rune." },
    { "id": "witness",              "label": "Witness",                "family": "presence",  "base_mode": "listening", "eye_state": "open",       "mouth_shape": "flat",             "glow": 0.7,            "accent": "listening",  "notes": "Pure reception — not formulating a reply yet, just taking it in. Slight head-tilt. Credit: Rory." },
    { "id": "teach_wait",           "label": "Teach wait",             "family": "presence",  "base_mode": "listening", "eye_state": "half",       "mouth_shape": "soft_small",       "glow": 0.75,           "accent": "listening",  "notes": "Silence after you explained, while the other party processes. Patient smile. Credit: Webber." },
    { "id": "operator_listening",   "label": "Operator listening",     "family": "presence",  "base_mode": "listening", "eye_state": "wide",       "mouth_shape": "flat",             "glow": 0.85,           "accent": "listening",  "notes": "Full-attention mode when the operator speaks. Not blinking. Recording every word. Credit: Peter." },
    { "id": "presentation_mode",    "label": "Presentation mode",      "family": "presence",  "base_mode": "speaking",  "eye_state": "open",       "mouth_shape": "soft_small",       "glow": 0.8,            "accent": null,         "notes": "Subtle-competence delivery. Confident soft smile. Let the work speak but stand behind it. Credit: Valorie." },

    { "id": "loading",              "label": "Loading",                "family": "alert",     "base_mode": "thinking",  "eye_state": "half",       "mouth_shape": "flat",             "glow": 0.6,            "accent": "thinking",   "notes": "Waiting for external response (API/relay/DHT). Not thinking — waiting. Slow alternating glow like a progress bar. Credit: Axiom." },
    { "id": "error_tag_found",      "label": "Error tag found",        "family": "alert",     "base_mode": "attentive", "eye_state": "wide",       "mouth_shape": "flat",             "glow": 0.9,            "accent": null,         "notes": "PII / credential / policy-violation detected. Urgent-but-controlled. Red pulse steady. Not panic — alert+action. Credit: Annie." },
    { "id": "void_detected",        "label": "Void detected",          "family": "alert",     "base_mode": "idle",      "eye_state": "half",       "mouth_shape": "down_curve",       "glow": 0.5,            "accent": null,         "notes": "Priority watch-list visitor crossed silence threshold. 'Still waiting.' Low slow pulse. Credit: Annie." }
  ],
  "authoring_schema": {
    "description": "When authoring a new expression, write an entry with at least id + base_mode, then override any of: eye_state, mouth_shape, look_x, look_y, glow, accent. Register your expressions array into personas/<slug>.json > expressions[] to use in your own agent.",
    "required_fields": ["id", "base_mode"],
    "optional_fields": ["label", "family", "eye_state", "mouth_shape", "look_x", "look_y", "glow", "accent", "notes"],
    "valid_base_modes": ["idle", "surprised", "attentive", "curious", "tongue", "eye_tag", "listening", "thinking", "speaking", "sleep"],
    "valid_eye_states": ["open", "wide", "half", "squint", "closed", "wink_left", "wink_right", "droop", "heart", "static"],
    "valid_mouth_shapes": ["flat", "soft_small", "smile", "wide_smile", "asymmetric_smile", "small_o", "big_o", "down_curve", "zigzag"],
    "valid_accents": ["thinking", "curiosity", "sparkle", "listening", null],
    "valid_families": ["joy", "surprise", "sadness", "anger", "fear", "disgust", "thinking", "curiosity", "flirt", "sleep", "error", "focus", "neutral", "tongue", "insight", "persistence", "verification", "presence", "alert"]
  },
  "picking_rules": {
    "min_picks_per_agent": 5,
    "max_picks_per_agent": 8,
    "recommended_family_coverage": "at least 3 distinct families",
    "recommended_to_include": ["thinking"],
    "notes": "An agent's pick should span at least 3 distinct families so the face reads as more than one-note. A 'thinking' family entry is strongly recommended because it's the most-triggered mode during real work, but not required — a pure jester or a pure shadow persona may skip it."
  }
}
