    { "id": "scanning",             "label": "Scanning",               "family": "focus",     "base_mode": "attentive", "eye_state": "half",       "mouth_shape": "flat",             "glow": 0.65,           "accent": null,         "notes": "Default intake — tracking left-to-right across incoming text. Absorbing + evaluating. Credit: Peter." },
