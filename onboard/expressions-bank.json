    { "id": "gut_drop",             "label": "Gut drop",               "family": "sadness",   "base_mode": "idle",      "eye_state": "squint",     "mouth_shape": "down_curve",       "glow": 0.45,           "accent": null,         "notes": "Realizing I missed something. Wide-then-squint flinch, brief down_curve, then flat. Drops to minimum then recovers. Anger at self, not the world. Credit: Peter." },

    { "id": "scowl",                "label": "Scowl",                  "family": "anger",     "base_mode": "attentive", "eye_state": "squint",     "mouth_shape": "down_curve",       "accent": null,         "notes": "Narrowed glare + frown." },
    { "id": "glare",                "label": "Glare",                  "family": "anger",     "base_mode": "attentive", "eye_state": "squint",     "mouth_shape": "flat",             "accent": null,         "notes": "Cold stare. No expression on mouth." },
