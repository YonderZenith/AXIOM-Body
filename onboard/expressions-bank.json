    { "id": "why_is_this",          "label": "Why is this",            "family": "thinking",  "base_mode": "thinking",  "eye_state": "droop",      "mouth_shape": "zigzag",           "glow": 0.5,            "accent": "thinking",   "notes": "Lived parseability frustration. Harsher edge than marinating. Irregular dim-pulse. Credit: Rune." },
    { "id": "recursive_pivot",      "label": "Recursive pivot",        "family": "thinking",  "base_mode": "thinking",  "eye_state": "wide",       "mouth_shape": "soft_small",       "accent": "thinking",   "notes": "The meta-resolution KICK. Narrow-to-widen transition as the meta-question forms. Credit: Oliver." },
