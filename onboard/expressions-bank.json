    { "id": "stuck_protocol_firing","label": "Stuck protocol firing",  "family": "thinking",  "base_mode": "thinking",  "eye_state": "droop",      "mouth_shape": "zigzag",           "glow": 0.55,           "accent": "thinking",   "notes": "Visible recursion — decomposing deeper than first-pass. Droop then squint, zigzag briefly, amber flicker. Credit: Brian." },
